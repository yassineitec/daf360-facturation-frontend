{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "d7f270b1-8a51-412c-b6fa-9290d27a388b"
  },
  "newProjectRoot": "projects",
  "projects": {
    "daf360-facturation-frontend": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "outputPath": "dist/daf360-facturation",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "polyfills": [
              "es-module-shims"
            ],
            "security": {
              "allowedHosts": []
            }
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.production.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "14kB"
                }
              ],
              "outputHashing": "media"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {},
          "configurations": {
            "production": {
              "target": "daf360-facturation-frontend:esbuild:production"
            },
            "development": {
              "target": "daf360-facturation-frontend:esbuild:development",
              "dev": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4204
          },
          "configurations": {
            "production": {
              "buildTarget": "daf360-facturation-frontend:esbuild:production"
            },
            "development": {
              "buildTarget": "daf360-facturation-frontend:esbuild:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "daf360-facturation-frontend:serve-original:development",
            "rebuildDelay": 500,
            "dev": true
          }
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
